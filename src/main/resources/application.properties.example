# DocuMind AI - Configuration Template
server.port=8080

# Database Configuration (Update with your local settings)
spring.datasource.url=jdbc:mysql://localhost:3306/documind
spring.datasource.username=root
spring.datasource.password=

# JWT Configuration
jwt.secret=documentMindSecretKeyForJWTTokenGenerationMustBeLongEnough123456789
jwt.expiration=86400000

# Gemini AI Configuration (Get your key from Google AI Studio)
gemini.api.key=YOUR_API_KEY_HERE
gemini.api.url=https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent

# File Upload Path
file.upload-dir=uploads